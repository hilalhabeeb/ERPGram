# Copy to .env and adjust. Never commit .env.

# Host port for the Docker web service. Defaults to 8010 — 8000 is often taken
# by editors (Cursor / VS Code), which shows up as a connection that drops.
WEB_PORT=8010

# Core
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=dev-insecure-change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

# Database — the app role must NOT be a superuser or have BYPASSRLS,
# otherwise the row-level-security policies are silently ignored.
DATABASE_URL=postgres://erpgram_app:erpgram_app_pw@localhost:5432/erpgram

# Django admin lives at a non-obvious, staff-only path.
DJANGO_ADMIN_URL=backoffice/

# Email (console backend in dev prints to stdout)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@erpgram.local

# Localisation defaults
LANGUAGE_CODE=en
TIME_ZONE=Asia/Bahrain

# --- production-only (ignored in dev) ---
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://erp.example.com
