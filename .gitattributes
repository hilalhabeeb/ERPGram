# Normalise line endings so the repo is identical on Windows, macOS and Linux.
* text=auto eol=lf

# Shell scripts and Dockerfiles MUST stay LF: a CRLF entrypoint makes the
# container fail to start with a confusing "no such file or directory".
*.sh text eol=lf
Dockerfile text eol=lf
docker/** text eol=lf
Makefile text eol=lf

# PowerShell is happiest with CRLF on Windows.
*.ps1 text eol=crlf

# Binary assets — never touch these.
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.mo binary
