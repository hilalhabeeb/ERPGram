# Production environment for docker-compose.prod.yml.
#
# Copy to .env.prod and fill in. NEVER commit the filled file — .env.prod is
# gitignored. Deploy with:
#
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# ---------------------------------------------------------------------------
# Domain & TLS
# ---------------------------------------------------------------------------
# The domain whose DNS A record points at this server. Caddy gets the HTTPS
# certificate for exactly this name.
DOMAIN=erp.example.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Generate a fresh one — do NOT reuse the dev key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-long-random-secret
# Must include the domain (comma-separated, no spaces).
ALLOWED_HOSTS=erp.example.com
# Full https origin(s), comma-separated. Required for POST/login to work.
CSRF_TRUSTED_ORIGINS=https://erp.example.com
# Admin URL prefix — pick something non-obvious rather than the default.
DJANGO_ADMIN_URL=backoffice/
# gunicorn worker count. Rule of thumb: (2 x CPU cores) + 1.
WEB_CONCURRENCY=3

# ---------------------------------------------------------------------------
# Database  (the two passwords are independent secrets — generate both)
# ---------------------------------------------------------------------------
# Superuser password for the Postgres container.
POSTGRES_PASSWORD=replace-with-a-strong-password
# Password for the least-privilege app role. Use letters/digits only (it is
# embedded in the DATABASE_URL and a SQL string). No spaces or quotes.
APP_DB_PASSWORD=replace-with-a-strong-alphanumeric-password

# ---------------------------------------------------------------------------
# Email  (for invitations and password resets)
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=ERPGRAM <no-reply@erp.example.com>
